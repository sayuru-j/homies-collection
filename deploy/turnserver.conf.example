# coturn on relay VM (host install, not Docker).
# Copy: sudo cp deploy/turnserver.conf.example /etc/turnserver.conf
# Set relay-ip to this VM's Azure private IP (ip -4 addr show eth0).
# Enable: echo 'TURNSERVER_ENABLED=1' | sudo tee /etc/default/coturn
# Restart: sudo systemctl restart coturn

